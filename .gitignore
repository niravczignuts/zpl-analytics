# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local

# local SQLite data
/data/

# test reports & artifacts
/tests/reports/
/tests/.auth/
/test-results/

# public uploads (player photos, logos) — keep folder, ignore contents
/public/players/*
!/public/players/.gitkeep
/public/logos/*
!/public/logos/.gitkeep
/public/scorecards/*
!/public/scorecards/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
