    "@types/papaparse": "^5.5.2",
    "@types/uuid": "^10.0.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^1.0.1",
    "next": "16.2.1",
